{
  "name": "goatmez-agent-os-v13",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Original Goatmez Agent OS v13 with local-first LLM routing, developer agent runtime, codebase tools, connector setup, approvals, dashboards, workflows, scheduling, MCP, and vault security.",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "validate:knowledge": "tsx src/scripts/validateKnowledgeV14.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "demo": "tsx src/cli.ts \"inspect this workspace\"",
    "dry": "tsx src/cli.ts --dry-run \"inspect this workspace\"",
    "dashboard": "tsx src/server/apiServer.ts",
    "dev:dashboard": "tsx src/server/apiServer.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.7",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
