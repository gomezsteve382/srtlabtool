# Goatmez Agent OS v12
# Planner routing: auto uses local model if GOATMEZ_LLM_BASE_URL is set, otherwise cloud if OPENAI_API_KEY is set, otherwise rules.
GOATMEZ_PLANNER_PROVIDER=auto

# Local/open-compatible model endpoint examples:
# Ollama: http://localhost:11434/v1
# LM Studio: http://localhost:1234/v1
# vLLM: http://localhost:8000/v1
GOATMEZ_LLM_BASE_URL=http://localhost:11434/v1
GOATMEZ_LOCAL_MODEL=llama3.1
GOATMEZ_LLM_API_KEY=local-dev-key

# Optional cloud fallback
OPENAI_API_KEY=
GOATMEZ_MODEL=gpt-4.1-mini
GOATMEZ_WORKSPACE_ROOT=.
GOATMEZ_DASHBOARD_PORT=8787

# Storage
GOATMEZ_DB_DRIVER=json
GOATMEZ_DB_PATH=.goatmez/database.json
GOATMEZ_KB_PATH=.goatmez/knowledge.json

# Knowledge search v14 (keyword | vector | hybrid)
GOATMEZ_KB_DEFAULT_SEARCH_MODE=keyword
GOATMEZ_KB_HYBRID_KEYWORD_WEIGHT=0.5

# Embeddings provider (off | mock | openai)
GOATMEZ_KB_EMBEDDINGS_PROVIDER=off
GOATMEZ_KB_MOCK_EMBED_DIMENSIONS=192
GOATMEZ_KB_EMBEDDINGS_MODEL=text-embedding-3-small
GOATMEZ_KB_EMBEDDINGS_BASE_URL=https://api.openai.com/v1

# Dashboard protection. Leave blank for local-only unlocked dev mode.
GOATMEZ_DASHBOARD_TOKEN=

# Scheduler
GOATMEZ_SCHEDULER_ENABLED=true
GOATMEZ_SCHEDULER_POLL_MS=15000

# Playbooks
GOATMEZ_PLAYBOOKS_CONFIG=

# Credential Vault
# Required for saving encrypted API keys/secrets. Use a long random value in production.
GOATMEZ_VAULT_KEY=change-me-to-a-long-random-local-master-key
GOATMEZ_VAULT_PATH=.goatmez/vault.json
GOATMEZ_CONNECTORS_CONFIG=

# For OPENAI embeddings mode, save OPENAI_API_KEY in vault (scope openai or workspace).

# v10 OAuth/provider adapter notes
# Store OAuth secrets in the encrypted vault, not directly in .env:
# GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REFRESH_TOKEN, GOOGLE_ACCESS_TOKEN
# GHL_API_KEY, GHL_LOCATION_ID, STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
